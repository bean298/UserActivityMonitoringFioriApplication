<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="viewSettingsDialog"
        title="View Settings"
        contentWidth="400px"
        contentHeight="500px"
        draggable="true"
        resizable="true">

        <VBox>

            <Title text="Columns" level="H5"/>

            <List
                id="columnList"
                mode="MultiSelect"
                items="{columnsModel>/columns}">

                <StandardListItem
                    title="{columnsModel>label}"
                    selected="{columnsModel>visible}" />

            </List>

        </VBox>

        <beginButton>
            <Button
                text="OK"
                press="onConfirmViewSettings"/>
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press="onCancelViewSettings"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>