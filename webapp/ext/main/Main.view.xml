<mvc:View xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:ui="sap.ui.table" controllerName="useraudit.ext.main.Main"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout" height="100%"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data">

    <f:DynamicPage id="mainDynamicPageId">

        <!-- TITLE | SUBTITLE -->
        <f:title>
            <f:DynamicPageTitle id="mainDynamicPageTitleId">
                <f:heading>
                    <Title id="titleId" text="{i18n>title}" />
                </f:heading>

                <f:expandedContent>
                    <Label id="subTitleId" text="{i18n>subTitle}" />
                </f:expandedContent>
            </f:DynamicPageTitle>
        </f:title>

        <!-- MAIN CONTENT -->
        <f:content>
            <VBox id="vBoxMainContent">

                <HBox id="hBoxChartContent" class="sapUiSmallMarginBottom">

                    <!-- DONUT CHART -->
                    <viz:VizFrame
                        vizProperties="{
                            title: { visible: true,  text: 'Login Result Overview' },
                            plotArea: {
                                colorPalette: ['#ff4d4f', '#52c41a'],
                                dataLabel: {  visible: true,  type: 'value' }
                            }
                        }"
                        id="loginChart" vizType="donut" width="400px" height="400px">

                        <!-- Define data of chart -->
                        <viz:dataset>
                            <viz.data:FlattenedDataset id="donutDataset" data="{authLogChart>/}">
                                <!-- Category  -->
                                <viz.data:dimensions>
                                    <viz.data:DimensionDefinition id="donutDimensionStatus"
                                        name="Status" value="{LoginResult}" />
                                </viz.data:dimensions>

                                <!-- Value -->
                                <viz.data:measures>
                                    <viz.data:MeasureDefinition id="donutMeasureCount" name="Count"
                                        value="{CountLoginLog}" />
                                </viz.data:measures>
                            </viz.data:FlattenedDataset>
                        </viz:dataset>

                        <!-- Mapping dimension/measure into chart -->
                        <viz:feeds>
                            <viz.feeds:FeedItem id="donutFeedColor" uid="color" type="Dimension"
                                values="Status" />
                            <viz.feeds:FeedItem id="donutFeedSize" uid="size" type="Measure"
                                values="Count" />
                        </viz:feeds>

                    </viz:VizFrame>
                </HBox>

                <!-- FILTER + SEARCH -->
                <Toolbar id="toolbarId" class="sapUiMediumMarginBottom" design="Transparent">

                    <Title id="filterTitleId" text="{i18n>filter}" level="H5"
                        class="sapUiSmallMarginEnd" />

                    <ToolbarSpacer id="filterToolbarSpacerId" />

                    <Input id="userSearchId" width="300px" placeholder="{i18n>searchUser}"
                        showValueHelp="true" liveChange="onSearchUserName"
                        valueHelpRequest="onUserSearchHelp" showClearIcon="true"
                        class="sapUiSmallMarginEnd" />

                    <Select id="mainHeaderSelectId" width="200px" change="onFilterStatus"
                        class="sapUiSmallMarginEnd">
                        <core:Item id="itemId1" key="" text="{i18n>all}" />
                        <core:Item id="itemId2" key="SUCCESS" text="{i18n>success}" />
                        <core:Item id="itemId3" key="FAIL" text="{i18n>failed}" />
                    </Select>

                    <!-- Date range filter -->
                    <DateRangeSelection id="mainDateRangeId" width="250px"
                        placeholder="{i18n>selectDateRange}" change="applyFilters" />

                </Toolbar>

                <!-- TABLE -->
                <ui:Table
                    id="maiTableId"
                    rows="{
                    path: '/UserAuthLog',
                    sorter: { path: 'LoginDate', descending: true }
                }"
                    selectionMode="None"
                    visibleRowCount="15"
                    visibleRowCountMode="Fixed"
                    navigationMode="Paginator"
                    firstVisibleRow="0"
                    enableColumnReordering="true"
                    class="sapUiLargeMarginBottom">
                    <!-- HEADER TOOLBAR -->
                    <ui:extension>
                        <OverflowToolbar id="mainToolbarId">
                            <Title id="mainTitleTableId"
                                text="{= ${i18n>headerTitleTable} + ' (' + ${view>/count} + ')' }"
                                level="H2" />

                            <ToolbarSpacer id="mainToolSpace" />

                            <!-- EXPORT BTN -->
                            <Button id="btnExportExcel" icon="sap-icon://excel-attachment"
                                tooltip="{i18n>exportExcel}" press="onExportExcel" />
                            <!-- VIEW SETTINGS BTN -->
                            <Button
                                id="btnViewSettings"
                                icon="sap-icon://action-settings"
                                tooltip="View Settings"
                                press="onOpenViewSettings" />
                        </OverflowToolbar>
                    </ui:extension>

                    <ui:columns>
                        <!-- SESSION ID COLUMN -->
                        <ui:Column id="columnSession" width="12rem">
                            <Label id="labelSession" text="{i18n>sessionId}" />

                            <ui:template>
                                <Text id="textSession" text="{SessionId}" wrapping="false" />
                            </ui:template>
                        </ui:Column>

                        <!-- USERNAME COLUMN -->
                        <ui:Column id="columnName" width="10rem">
                            <Label id="labelName" text="{i18n>username}" />

                            <ui:template>
                                <Text id="textName" text="{Username}" wrapping="false" />
                            </ui:template>
                        </ui:Column>

                        <!-- LOGIN RESULT COLUMN -->
                        <ui:Column id="columnLoginResult" width="9rem">
                            <Label id="labelLoginResult" text="{i18n>loginResult}" />

                            <ui:template>
                                <ObjectStatus id="textLoginResult" text="{LoginResult}"
                                    icon="{path: 'LoginResult', formatter: '.formatter.formatLoginResultIcon'}"
                                    state="{path: 'LoginResult', formatter: '.formatter.formatLoginResultState'}" />
                            </ui:template>
                        </ui:Column>

                        <!-- LOGIN DATE COLUMN -->
                        <ui:Column id="columnLoginDate" width="9rem">
                            <Label id="labelLoginDate" text="{i18n>loginDate}" />

                            <ui:template>
                                <Text id="textLoginDate" text="{LoginDate}" />
                            </ui:template>
                        </ui:Column>

                        <!-- LOGIN TIME COLUMN -->
                        <ui:Column id="columnLoginTime" width="7rem">
                            <Label id="labelLoginTime" text="{i18n>loginTime}" />

                            <ui:template>
                                <Text id="textLoginTime" text="{LoginTime}" />
                            </ui:template>
                        </ui:Column>

                        <!-- LOGIN MESSAGE COLUMN -->
                        <ui:Column id="columnLoginMessage" width="18rem">
                            <Label id="labelLoginMessage" text="{i18n>loginMessage}" />

                            <ui:template>
                                <ObjectStatus id="textLoginMessage" text="{LoginMessage}"
                                    icon="{path: 'EventId', formatter: '.formatter.formatLoginMessageIcon'}"
                                    state="{path: 'EventId', formatter: '.formatter.formatLoginMessageState'}" />
                            </ui:template>
                        </ui:Column>

                        <!-- LOGOUT DATE COLUMN -->
                        <ui:Column id="columnLogoutDate" width="9rem">
                            <Label id="laeblLogoutDate" text="{i18n>logoutDate}" />

                            <ui:template>
                                <Text id="textLogoutDate" text="{LogoutDate}" />
                            </ui:template>
                        </ui:Column>

                        <!-- LOGOUT TIME COLUMN -->
                        <ui:Column id="columnLogoutTime" width="7rem">
                            <Label id="labelLogoutTime" text="{i18n>logoutTime}" />

                            <ui:template>
                                <Text id="textLogoutTime" text="{LogoutTime}" />
                            </ui:template>
                        </ui:Column>

                        <!-- NAVIGATOR COLUMN -->
                        <ui:Column id="columnNavigator" width="4rem" hAlign="Center">
                            <ui:template>
                                <Button id="btnNavigator" icon="sap-icon://navigation-right-arrow"
                                    type="Transparent" press="onPressNavigate" />
                            </ui:template>
                        </ui:Column>
                    </ui:columns>

                </ui:Table>

            </VBox>
        </f:content>

    </f:DynamicPage>
</mvc:View>