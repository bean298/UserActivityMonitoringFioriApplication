<mvc:View xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m" 
    xmlns:ui="sap.ui.table"
    controllerName="useraudit.ext.main.Main"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout" height="100%"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data">

    <f:DynamicPage id="mainDynamicPageId">

        <!-- TITLE | SUBTITLE -->
        <f:title>
            <f:DynamicPageTitle id="mainDynamicPageTitleId">
                <f:heading>
                    <Title id="titleId" text="{i18n>title}" />
                </f:heading>

                <f:expandedContent>
                    <Label id="subTitleId" text="{i18n>subTitle}" />
                </f:expandedContent>
            </f:DynamicPageTitle>
        </f:title>

        <!-- MAIN CONTENT -->
        <f:content>
            <VBox id="vBoxMainContent">

                <HBox id="hBoxChartContent" class="sapUiSmallMarginBottom">

                    <!-- DONUT CHART -->
                    <viz:VizFrame
                        vizProperties="{
                            title: { visible: true,  text: 'Login Result Overview' },
                            plotArea: {
                                colorPalette: ['#ff4d4f', '#52c41a'],
                                dataLabel: {  visible: true,  type: 'value' }
                            }
                        }"
                        id="loginChart"
                        vizType="donut"
                        width="400px"
                        height="400px">

                        <viz:dataset>
                            <viz.data:FlattenedDataset
                                id="donutDataset"
                                data="{authLogChart>/}">

                                <viz.data:dimensions>
                                    <viz.data:DimensionDefinition
                                        id="donutDimensionStatus"
                                        name="Status"
                                        value="{LoginResult}" />
                                </viz.data:dimensions>

                                <viz.data:measures>
                                    <viz.data:MeasureDefinition
                                        id="donutMeasureCount"
                                        name="Count"
                                        value="{CountLoginLog}" />
                                </viz.data:measures>

                            </viz.data:FlattenedDataset>
                        </viz:dataset>

                        <viz:feeds>
                            <viz.feeds:FeedItem
                                id="donutFeedColor"
                                uid="color"
                                type="Dimension"
                                values="Status" />
                            <viz.feeds:FeedItem
                                id="donutFeedSize"
                                uid="size"
                                type="Measure"
                                values="Count" />
                        </viz:feeds>

                    </viz:VizFrame>
                </HBox>

                <!-- FILTER + SEARCH -->
                <Toolbar
                    id="toolbarId"
                    class="sapUiMediumMarginBottom"
                    design="Transparent">

                    <Title
                        id="filterTitleId"
                        text="Filters"
                        level="H5"
                        class="sapUiSmallMarginEnd"/>

                    <ToolbarSpacer id="filterToolbarSpacerId"/>

                    <Input
                        id="userSearchId"
                        width="300px"
                        placeholder="Search User"
                        showValueHelp="true"
                        liveChange="onSearchUserName"
                        valueHelpRequest="onUserSearchHelp"
                        showClearIcon="true"
                        class="sapUiSmallMarginEnd" />

                    <Select
                        id="mainHeaderSelectId"
                        width="200px"
                        change="onFilterStatus"
                        class="sapUiSmallMarginEnd">

                        <core:Item id="itemId1" key="" text="All" />
                        <core:Item id="itemId2" key="SUCCESS" text="Success" />
                        <core:Item id="itemId3" key="FAIL" text="Failed" />
                    </Select>

                    <!-- Date range filter -->
                    <DateRangeSelection
                        id="mainDateRangeId"
                        width="250px"
                        placeholder="Select date range..."
                        change=".applyFilters"/>

                </Toolbar>

                <!-- TABLE -->
                <ui:Table
    id="maiTableId"
    rows="{
        path: '/UserAuthLog',
        sorter: { path: 'LoginDate', descending: true }
    }"
    visibleRowCount="10" 
    fixedVisibleRowCount="true"  selectionMode="None"
    navigationMode="Paginator"
    class="sapUiLargeMarginBottom">
                <ui:extension>
            <OverflowToolbar id="mainToolbarId">
            <Title
                id="mainTitleTableId"
                text="{= ${i18n>headerTitleTable} + ' (' + ${view>/count} + ')' }"
                level="H2" />
            <ToolbarSpacer id="mainToolSpace" />
            
            <Label text="Rows per page:"/>
            <Select id="rowCountSelect" change="onRowCountChange" selectedKey="10" width="100px">
                <core:Item key="10" text="10"/>
                <core:Item key="25" text="25"/>
                <core:Item key="50" text="50"/>
                <core:Item key="100" text="100"/>
            </Select>

            <Button
                id="btnExportExcel"
                icon="sap-icon://excel-attachment"
                tooltip="Export Excel"
                press=".onExportExcel" />
        </OverflowToolbar>
    </ui:extension>

    <ui:columns>
        <ui:Column width="12rem">
            <Label text="{i18n>sessionId}" />
            <ui:template>
                <Text text="{SessionId}" wrapping="false" />
            </ui:template>
        </ui:Column>

        <ui:Column width="10rem">
            <Label text="{i18n>username}" />
            <ui:template>
                <Text text="{Username}" wrapping="false" />
            </ui:template>
        </ui:Column>

        <ui:Column width="9rem">
            <Label text="{i18n>loginResult}" />
            <ui:template>
                <ObjectStatus
                    text="{LoginResult}"
                    icon="{path: 'LoginResult', formatter: '.formatter.formatLoginResultIcon'}"
                    state="{path: 'LoginResult', formatter: '.formatter.formatLoginResultState'}" />
            </ui:template>
        </ui:Column>

        <ui:Column width="9rem">
            <Label text="{i18n>loginDate}" />
            <ui:template>
                <Text text="{LoginDate}" />
            </ui:template>
        </ui:Column>

        <ui:Column width="7rem">
            <Label text="{i18n>loginTime}" />
            <ui:template>
                <Text text="{LoginTime}" />
            </ui:template>
        </ui:Column>

        <ui:Column width="18rem">
            <Label text="{i18n>loginMessage}" />
            <ui:template>
                <ObjectStatus
                    text="{LoginMessage}"
                    icon="{path: 'EventId', formatter: '.formatter.formatLoginMessageIcon'}"
                    state="{path: 'EventId', formatter: '.formatter.formatLoginMessageState'}" />
            </ui:template>
        </ui:Column>

        <ui:Column width="9rem">
            <Label text="{i18n>logoutDate}" />
            <ui:template>
                <Text text="{LogoutDate}" />
            </ui:template>
        </ui:Column>

        <ui:Column width="7rem">
            <Label text="{i18n>logoutTime}" />
            <ui:template>
                <Text text="{LogoutTime}" />
            </ui:template>
        </ui:Column>
        <ui:Column width="4rem" hAlign="Center">
    <Label text="" />
    <ui:template>
        <Button 
            icon="sap-icon://navigation-right-arrow" 
            type="Transparent"
            press="onPressNavigate" /> 
            </ui:template>
</ui:Column>
    </ui:columns>
    
</ui:Table>

            </VBox>
        </f:content>

    </f:DynamicPage>
</mvc:View>