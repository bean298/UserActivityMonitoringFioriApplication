<mvc:View xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.uxap"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout" controllerName="useraudit.controller.UserDetail" height="100%"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:ui="sap.ui.table">

    <f:ObjectPageLayout id="UserDetailObjectPageLayoutId" showTitleInHeaderContent="true"
        upperCaseAnchorBar="false">
        <!-- HEADER TITLE -->
        <f:headerTitle>
            <f:ObjectPageDynamicHeaderTitle id="UserDetailHeaderTitleId">
                <f:expandedHeading>
                    <Title id="UserDetailExpandedTitleId" text="{i18n>userDetailTitle}" level="H2" />
                </f:expandedHeading>

                <f:snappedHeading>
                    <Title id="UserDetailSnappedTitleId" text="{UserDetailData>/UserName}"
                        level="H3" />
                </f:snappedHeading>
            </f:ObjectPageDynamicHeaderTitle>
        </f:headerTitle>

        <!-- HEADER CONTENT -->
        <f:headerContent>
            <FlexBox id="UserDetailHeaderFlexId" alignItems="Center" wrap="Wrap"
                class="sapUiMediumMargin">
                <!-- AVATAR -->
                <Avatar id="UserDetailAvatarId" displaySize="XL" displayShape="Circle"
                    initials="{UserDetailData>/UserName}" backgroundColor="Accent6"
                    class="sapUiMediumMarginEnd" />

                <!-- USER INFO -->
                <VBox id="UserDetailHeaderInfoBoxId" width="300px">
                    <Title id="UserDetailHeaderUserNameId" text="{UserDetailData>/UserName}"
                        level="H3" />

                    <Text id="UserDetailHeaderFullNameId" text="{UserDetailData>/FullName}"
                        class="sapUiTinyMarginBottom" />

                    <!-- USER STATUS -->
                    <ObjectStatus id="UserDetailHeaderStatusId"
                        text="{
                        path:'UserDetailData>/LockStatus',
                        formatter:'.formatter.formatTextLockStatus'
                    }"
                        state="{
                        path:'UserDetailData>/LockStatus',
                        formatter:'.formatter.formatTextLockState'
                    }"
                        icon="{
                        path:'UserDetailData>/LockStatus',
                        formatter:'.formatter.formatTextLockIcon'
                    }" />
                </VBox>
            </FlexBox>
        </f:headerContent>
        <!-- SECTIONS -->
        <f:sections>
            <!-- USER INFORMATION -->
            <f:ObjectPageSection id="UserDetailSectionCombinedId" title="{i18n>userDetailTitle}">
                <f:subSections>
                    <f:ObjectPageSubSection id="UserDetailSubSectionCombinedId">
                        <layout:Grid id="UserDetailGridCombinedId" defaultSpan="L2 M4 S12">

                            <VBox id="BoxUserInfo">
                                <Label text="{i18n>username}" design="Bold" />
                                <Text text="{UserDetailData>/UserName}" />

                                <Label text="{i18n>fullName}" design="Bold"
                                    class="sapUiSmallMarginTop" />
                                <Text text="{UserDetailData>/FullName}" />
                            </VBox>

                            <VBox id="BoxGroupInfo">
                                <Label text="{i18n>userGroup}" design="Bold" />
                                <ObjectStatus text="{UserDetailData>/UserGroup}" state="Information"
                                    icon="sap-icon://group" />

                                <Label text="{i18n>email}" design="Bold" class="sapUiSmallMarginTop" />
                                <Link text="{UserDetailData>/EmailAddress}"
                                    href="mailto:{UserDetailData>/EmailAddress}" />
                            </VBox>

                            <VBox id="BoxAddressGeneral">
                                <Label text="{i18n>addressName}" design="Bold" />
                                <Text text="{UserDetailData>/AddressName}" />

                                <Label text="{i18n>city}" design="Bold" class="sapUiSmallMarginTop" />
                                <Text text="{UserDetailData>/City}" />
                            </VBox>

                            <VBox id="BoxAddressDetail">
                                <Label text="{i18n>street}" design="Bold" />
                                <Text text="{UserDetailData>/Street}" />

                                <Label text="{i18n>postalCode}" design="Bold"
                                    class="sapUiSmallMarginTop" />
                                <Text text="{UserDetailData>/PostalCode}" />
                            </VBox>

                            <VBox id="BoxValidity">
                                <Label text="{i18n>validFrom}" design="Bold" />
                                <Text
                                    text="{path:'UserDetailData>/ValidFrom', formatter:'.formatter.formatISODate'}" />

                                <Label text="{i18n>validTo}" design="Bold"
                                    class="sapUiSmallMarginTop" />
                                <Text
                                    text="{path:'UserDetailData>/ValidTo', formatter:'.formatter.formatISODate'}" />
                            </VBox>

                            <VBox id="BoxCreationInfo">
                                <Label text="{i18n>createdBy}" design="Bold" />
                                <Text text="{UserDetailData>/Creator}" />

                                <Label text="{i18n>createdOn}" design="Bold"
                                    class="sapUiSmallMarginTop" />
                                <Text
                                    text="{path:'UserDetailData>/CreateOn', formatter:'.formatter.formatISODate'}" />
                            </VBox>

                        </layout:Grid>
                    </f:ObjectPageSubSection>
                </f:subSections>
            </f:ObjectPageSection>

            <!-- AUTHENTICATION -->
            <f:ObjectPageSection id="UserDetailSectionAuth" title="{i18n>auth}">
                <f:subSections>
                    <f:ObjectPageSubSection id="UserDetailSubSectionAuth">
                        <VBox id="AuthBoxId" class="sapUiMediumMargin sapUiContentPadding">
                            <!-- AUTH - DONUT CHART -->
                            <HBox id="hBoxChart" class="sapUiSmallMarginBottom"
                                justifyContent="SpaceAround">
                                <viz:VizFrame id="AuthVizFrameId" height="300px" width="400px"
                                    vizType="donut"
                                    vizProperties="{
                                    title: {
                                        text: 'User Authentication Result'
                                    },
                                    plotArea: {
                                        colorPalette: ['#e74c3c', '#2ecc71'],
                                        dataLabel: {
                                            visible: true
                                        }
                                    },
                                    legend: {
                                        visible: true
                                    }
                                }">
                                    <!-- Define data of chart -->
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset id="AuthDatasetId"
                                            data="{AuthLogChartByUserData>/}">
                                            <!-- Category -->
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition
                                                    id="AuthDimLoginResultId" name="Login Result"
                                                    value="{AuthLogChartByUserData>LoginResult}" />
                                            </viz.data:dimensions>

                                            <!-- Value  -->
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition id="AuthMeasureCountId"
                                                    name="Count"
                                                    value="{AuthLogChartByUserData>CountLoginLog}" />
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>

                                    <!-- Mapping dimension/measure into chart -->
                                    <viz:feeds>
                                        <viz.feeds:FeedItem id="AuthFeedSizeId" uid="size"
                                            type="Measure" values="Count" />
                                        <viz.feeds:FeedItem id="AuthFeedColorId" uid="color"
                                            type="Dimension" values="Login Result" />
                                    </viz:feeds>
                                </viz:VizFrame>

                                <!-- AUTH PER DAY - COLUMN CHART -->
                                <viz:VizFrame id="AuthPerDayVizFrameId" height="300px" width="500px"
                                    vizType="column"
                                    vizProperties="{
                                    title: {
                                        text: 'User Log (Last 6 Days)'
                                    },
                                    plotArea: {
                                        dataLabel: {
                                            visible: true,
                                            formatString: '0'
                                        }
                                    },
                                    valueAxis: {
                                        label: {
                                            formatString: '0'
                                        }
                                    },
                                    legend: {
                                        visible: true
                                    }
                                }">
                                    <!-- Define data of chart -->
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset id="AuthPerDayDatasetId"
                                            data="{UserAuthLogPerDayData>/}">
                                            <!-- DIMENSION -->
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition
                                                    id="AuthPerDayDimLoginResultId" name="Date"
                                                    value="{UserAuthLogPerDayData>LoginDate}" />
                                            </viz.data:dimensions>

                                            <!-- MEASURE -->
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition
                                                    id="AuthPerDayMeasureCountId" name="Login Count"
                                                    value="{UserAuthLogPerDayData>TotalLoginCount}" />
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>

                                    <!-- Mapping dimension/measure into chart -->
                                    <viz:feeds>
                                        <viz.feeds:FeedItem id="AuthPerDayFeedSizeId"
                                            uid="categoryAxis" type="Dimension" values="Date" />
                                        <viz.feeds:FeedItem id="AuthPerDayFeedColorId"
                                            uid="valueAxis" type="Measure" values="Login Count" />
                                    </viz:feeds>
                                </viz:VizFrame>
                            </HBox>
                            <!-- AUTHENTICATION -->
                            <!-- FILTER PANEL -->
                            <Toolbar class="sapUiSmallMarginBottom" design="Transparent">

                                <Title text="{i18n>userAuthentication}" level="H2" />

                                <ToolbarSpacer />

                                <!-- STATUS -->
                                <Label
                                    text="{i18n>status}"
                                    class="sapUiSmallMarginBegin sapUiSmallMarginEnd" />

                                <Select
                                    width="180px"
                                    change="onFilterAuth"
                                    class="sapUiSmallMarginEnd">
                                    <core:Item key="" text="{i18n>all}" />
                                    <core:Item key="SUCCESS" text="{i18n>success}" />
                                    <core:Item key="FAILED" text="{i18n>failed}" />
                                </Select>

                                <!-- DATE -->
                                <Label
                                    text="{i18n>filterDate}"
                                    class="sapUiSmallMarginBegin sapUiSmallMarginEnd" />

                                <DatePicker
                                    width="180px"
                                    change="onFilterAuth"
                                    class="sapUiSmallMarginEnd" />

                            </Toolbar>

                            <!-- AUTH TABLE -->
                            <ui:Table
                                id="AuthTableId"
                                rows="{
        path: 'UserAuthLogData>/',
        sorter: {
            path: 'LoginDate',
            descending: true
        }
    }"
                                visibleRowCount="6"
                                selectionMode="Single"
                                alternateRowColors="true"
                                class="sapUiLargeMarginBottom">

                                <!-- HEADER -->
                                <ui:extension>
                                    <OverflowToolbar>

                                        <Title
                                            text="{= ${i18n>headerTitleTable} + ' (' + ${view>/count} + ')' }"
                                            level="H2" />

                                        <ToolbarSpacer />

                                        <Button
                                            icon="sap-icon://refresh"
                                            tooltip="{i18n>refreshData}"
                                            press="onRefreshTable" />

                                        <Button
                                            icon="sap-icon://excel-attachment"
                                            tooltip="{i18n>exportExcel}"
                                            press="onExportExcel" />

                                    </OverflowToolbar>
                                </ui:extension>

                                <!-- COLUMNS -->
                                <ui:columns>

                                    <!-- SESSION ID -->
                                    <ui:Column width="14rem">
                                        <Label text="{i18n>sessionId}" />
                                        <ui:template>
                                            <Text text="{UserAuthLogData>SessionId}"
                                                wrapping="false" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- LOGIN RESULT -->
                                    <ui:Column width="9rem">
                                        <Label text="{i18n>loginResult}" />

                                        <ui:template>
                                            <ObjectStatus
                                                text="{UserAuthLogData>LoginResult}"
                                                icon="{path:'UserAuthLogData>LoginResult', formatter:'.formatter.formatLoginResultIcon'}"
                                                state="{path:'UserAuthLogData>LoginResult', formatter:'.formatter.formatLoginResultState'}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- LOGIN DATE -->
                                    <ui:Column width="10rem">
                                        <Label text="{i18n>loginDate}" />
                                        <ui:template>
                                            <Text
                                                text="{path:'UserAuthLogData>LoginDate', formatter:'.formatter.formatISODate'}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- LOGIN TIME -->
                                    <ui:Column width="8rem">
                                        <Label text="{i18n>loginTime}" />
                                        <ui:template>
                                            <Text text="{UserAuthLogData>LoginTime}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- LOGIN MESSAGE -->
                                    <ui:Column>
                                        <Label text="{i18n>loginMessage}" />
                                        <ui:template>
                                            <ObjectStatus
                                                text="{UserAuthLogData>LoginMessage}"
                                                icon="{path:'UserAuthLogData>EventId', formatter:'.formatter.formatLoginMessageIcon'}"
                                                state="{path:'UserAuthLogData>EventId', formatter:'.formatter.formatLoginMessageState'}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- LOGOUT DATE -->
                                    <ui:Column width="10rem">
                                        <Label text="{i18n>logoutDate}" />
                                        <ui:template>
                                            <Text
                                                text="{path:'UserAuthLogData>LogoutDate', formatter:'.formatter.formatISODate'}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- LOGOUT TIME -->
                                    <ui:Column width="8rem">
                                        <Label text="{i18n>logoutTime}" />
                                        <ui:template>
                                            <Text
                                                text="{path:'UserAuthLogData>LogoutTime', formatter:'.formatter.formatLogoutTime'}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- NAVIGATE -->
                                    <ui:Column width="5rem" hAlign="Center">
                                        <ui:template>
                                            <Button
                                                icon="sap-icon://navigation-right-arrow"
                                                type="Transparent"
                                                press="onNavigationToAuthDetail" />
                                        </ui:template>
                                    </ui:Column>

                                </ui:columns>
                            </ui:Table>
                        </VBox>
                    </f:ObjectPageSubSection>
                </f:subSections>
            </f:ObjectPageSection>

            <!-- ACTIVITY -->
            <f:ObjectPageSection id="UserDetailSectionActivity" title="{i18n>activity}">
                <f:subSections>
                    <f:ObjectPageSubSection id="UserDetailSubSectionActivity">
                        <VBox id="ActivityVBoxId" class="sapUiMediumMargin sapUiContentPadding">
                            <!-- TCODE USAGE - PIE CHART -->
                            <viz:VizFrame
                                vizProperties="{
                                title: { visible: true, text: 'Top 5 TCode Usage By User' },
                                plotArea: {
                                    dataLabel: {
                                        visible: true,
                                        type: 'percentage'
                                    }
                                }
                            }"
                                id="tcodeChartByUser" vizType="pie" width="500px" height="300px">
                                <!-- Define data of chart -->
                                <!-- Define data of chart -->
                                <viz:dataset>
                                    <viz.data:FlattenedDataset id="TCodeByUserDatasetId"
                                        data="{TCodeByUserData>/}">
                                        <!-- DIMENSION -->
                                        <viz.data:dimensions>
                                            <viz.data:DimensionDefinition id="TCodeByUserDimId"
                                                name="Label" value="{TCodeByUserData>Label}" />
                                        </viz.data:dimensions>

                                        <!-- MEASURE -->
                                        <viz.data:measures>
                                            <viz.data:MeasureDefinition
                                                id="TCodeByUserMeasureCountId" name="Usage"
                                                value="{TCodeByUserData>TCodeCount}" />
                                        </viz.data:measures>
                                    </viz.data:FlattenedDataset>
                                </viz:dataset>

                                <!-- Mapping dimension/measure into chart -->
                                <viz:feeds>
                                    <viz.feeds:FeedItem id="ActTcodeMeasure" uid="size"
                                        type="Measure" values="Usage" />
                                    <viz.feeds:FeedItem id="ActTcodeValue" uid="color"
                                        type="Dimension" values="Label" />
                                </viz:feeds>
                            </viz:VizFrame>
                            <!-- ACTIVITY -->
                            <VBox class="sapUiMediumMarginTop">

                                <!-- FILTER BAR -->
                                <Toolbar class="sapUiSmallMarginBottom" design="Transparent">

                                    <Title text="{i18n>activity}" level="H2" />

                                    <ToolbarSpacer />

                                    <!-- Activity Type -->
                                    <Label text="{i18n>activityType}" class="sapUiTinyMarginEnd" />
                                    <Select width="140px" change="onFilterActivity">
                                        <core:Item key="" text="All" />
                                        <core:Item key="TCODE" text="TCODE" />
                                        <core:Item key="DUMP" text="DUMP" />
                                    </Select>

                                    <!-- TCode -->
                                    <Label text="TCode"
                                        class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />
                                    <Input width="120px" placeholder="TCode"
                                        liveChange="onFilterActivity" />

                                    <!-- Date -->
                                    <Label text="{i18n>activityDate}"
                                        class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />
                                    <DatePicker width="150px" change="onFilterActivity" />

                                </Toolbar>

                                <!-- TABLE -->
                                <ui:Table
                                    id="ActivityTableId"
                                    rows="{
        path: 'UserActivityLogData>/',
        sorter: {
            path: 'ActivityDate',
            descending: true
        }
    }"
                                    visibleRowCount="8"
                                    selectionMode="None"
                                    alternateRowColors="true"
                                    class="sapUiLargeMarginBottom">

                                    <!-- HEADER TOOLBAR -->
                                    <ui:extension>
                                        <OverflowToolbar>

                                            <Title
                                                text="{= ${i18n>activity} + ' (' + ${view>/count} + ')' }"
                                                level="H2" />

                                            <ToolbarSpacer />

                                            <!-- EXPORT -->
                                            <Button
                                                icon="sap-icon://excel-attachment"
                                                tooltip="{i18n>exportExcel}"
                                                press="onExportActivityExcel" />

                                            <!-- SETTINGS -->
                                            <Button
                                                icon="sap-icon://action-settings"
                                                tooltip="{i18n>settings}"
                                                press="onOpenActivitySettings" />

                                        </OverflowToolbar>
                                    </ui:extension>

                                    <!-- COLUMNS -->
                                    <ui:columns>

                                        <!-- LOG ID -->
                                        <ui:Column width="14rem">
                                            <Label text="{i18n>logId}" />
                                            <ui:template>
                                                <Text text="{UserActivityLogData>LogId}"
                                                    wrapping="false" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- ACTIVITY TYPE -->
                                        <ui:Column width="10rem" hAlign="Center">
                                            <Label text="{i18n>activityType}" />
                                            <ui:template>
                                                <ObjectStatus
                                                    text="{UserActivityLogData>ActivityType}"
                                                    icon="{path:'UserActivityLogData>ActivityType', formatter:'.formatter.formatActivityType'}"
                                                    state="{path:'UserActivityLogData>ActivityType', formatter:'.formatter.formatActivityState'}" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- TCODE -->
                                        <ui:Column width="8rem">
                                            <Label text="{i18n>tCode}" />
                                            <ui:template>
                                                <ObjectStatus
                                                    text="{UserActivityLogData>TCode}"
                                                    icon="{path:'UserActivityLogData>TCode', formatter:'.formatter.formatTCodeIcon'}" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- TCODE NAME -->
                                        <ui:Column width="12rem">
                                            <Label text="{i18n>tCodeName}" />
                                            <ui:template>
                                                <Text text="{UserActivityLogData>TCodeName}"
                                                    wrapping="false" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- MESSAGE -->
                                        <ui:Column>
                                            <Label text="{i18n>activityMessage}" />
                                            <ui:template>
                                                <ObjectStatus
                                                    text="{UserActivityLogData>ActivityMessage}"
                                                    state="Information" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- DATE -->
                                        <ui:Column width="10rem">
                                            <Label text="{i18n>activityDate}" />
                                            <ui:template>
                                                <Text
                                                    text="{path:'UserActivityLogData>ActivityDate', formatter: '.formatter.formatISODate'}" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- TIME -->
                                        <ui:Column width="8rem">
                                            <Label text="{i18n>activityTime}" />
                                            <ui:template>
                                                <Text text="{UserActivityLogData>ActivityTime}" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- NAVIGATION -->
                                        <ui:Column width="4rem" hAlign="Center">
                                            <ui:template>
                                                <Button
                                                    icon="sap-icon://navigation-right-arrow"
                                                    type="Transparent"
                                                    press="onPressActivityDetail" />
                                            </ui:template>
                                        </ui:Column>

                                    </ui:columns>
                                </ui:Table>
                            </VBox>
                        </VBox>
                    </f:ObjectPageSubSection>
                </f:subSections>
            </f:ObjectPageSection>
        </f:sections>
    </f:ObjectPageLayout>
</mvc:View>