<mvc:View xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.uxap"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout" controllerName="useraudit.controller.UserDetail" height="100%"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:ui="sap.ui.table">
    <f:ObjectPageLayout id="UserDetailObjectPageLayoutId" showTitleInHeaderContent="true"
        upperCaseAnchorBar="false">
        <!-- HEADER TITLE -->
        <f:headerTitle>
            <f:ObjectPageDynamicHeaderTitle id="UserDetailHeaderTitleId">
                <f:expandedHeading>
                    <Title id="UserDetailExpandedTitleId" text="{i18n>userDetailTitle}" level="H2" />
                </f:expandedHeading>

                <f:snappedHeading>
                    <Title id="UserDetailSnappedTitleId" text="{UserDetailData>/UserName}"
                        level="H3" />
                </f:snappedHeading>
            </f:ObjectPageDynamicHeaderTitle>
        </f:headerTitle>

        <!-- HEADER CONTENT -->
        <f:headerContent>
            <FlexBox id="UserDetailHeaderFlexId" alignItems="Center" wrap="Wrap"
                class="sapUiMediumMargin">
                <!-- AVATAR -->
                <Avatar id="UserDetailAvatarId" displaySize="XL" displayShape="Circle"
                    initials="{UserDetailData>/UserName}" backgroundColor="Accent6"
                    class="sapUiMediumMarginEnd" />

                <!-- USER INFO -->
                <VBox id="UserDetailHeaderInfoBoxId" width="300px">
                    <Title id="UserDetailHeaderUserNameId" text="{UserDetailData>/UserName}"
                        level="H3" />

                    <Text id="UserDetailHeaderFullNameId" text="{UserDetailData>/FullName}"
                        class="sapUiTinyMarginBottom" />

                    <!-- USER STATUS -->
                    <ObjectStatus id="UserDetailHeaderStatusId"
                        text="{
                        path:'UserDetailData>/LockStatus',
                        formatter:'.formatter.formatTextLockStatus'
                    }"
                        state="{
                        path:'UserDetailData>/LockStatus',
                        formatter:'.formatter.formatTextLockState'
                    }"
                        icon="{
                        path:'UserDetailData>/LockStatus',
                        formatter:'.formatter.formatTextLockIcon'
                    }" />
                </VBox>
            </FlexBox>
        </f:headerContent>
        <!-- SECTIONS -->
        <f:sections>
            <!-- USER INFORMATION -->
            <f:ObjectPageSection id="UserDetailSectionCombinedId" title="{i18n>userDetailTitle}">
                <f:subSections>
                    <f:ObjectPageSubSection id="UserDetailSubSectionCombinedId">
                        <layout:Grid id="UserDetailGridCombinedId" defaultSpan="L2 M4 S12">
                            <VBox id="UserInfoBoxId">
                                <Label id="UserInfoUsernameLabelId" text="{i18n>username}"
                                    design="Bold" />
                                <Text id="UserInfoUsernameTextId" text="{UserDetailData>/UserName}" />

                                <Label id="UserInfoFullNameLabelId" text="{i18n>fullName}"
                                    design="Bold" class="sapUiSmallMarginTop" />
                                <Text id="UserInfoFullNameTextId" text="{UserDetailData>/FullName}" />
                            </VBox>

                            <VBox id="BoxGroupInfo">
                                <Label id="UserGroupLabelId" text="{i18n>userGroup}" design="Bold" />
                                <ObjectStatus id="UserGroupStatusId"
                                    text="{UserDetailData>/UserGroup}" state="Information"
                                    icon="sap-icon://group" />

                                <Label id="UserEmailLabelId" text="{i18n>email}" design="Bold"
                                    class="sapUiSmallMarginTop" />
                                <Link id="UserEmailLinkId" text="{UserDetailData>/EmailAddress}"
                                    href="mailto:{UserDetailData>/EmailAddress}" />
                            </VBox>

                            <VBox id="BoxAddressGeneral">
                                <Label id="AddressNameLabelId" text="{i18n>addressName}"
                                    design="Bold" />
                                <Text id="AddressNameTextId" text="{UserDetailData>/AddressName}" />

                                <Label id="CityLabelId" text="{i18n>city}" design="Bold"
                                    class="sapUiSmallMarginTop" />
                                <Text id="CityTextId" text="{UserDetailData>/City}" />
                            </VBox>

                            <VBox id="BoxAddressDetail">
                                <Label id="StreetLabelId" text="{i18n>street}" design="Bold" />
                                <Text id="StreetTextId" text="{UserDetailData>/Street}" />

                                <Label id="PostalCodeLabelId" text="{i18n>postalCode}" design="Bold"
                                    class="sapUiSmallMarginTop" />
                                <Text id="PostalCodeTextId" text="{UserDetailData>/PostalCode}" />
                            </VBox>

                            <VBox id="BoxValidity">
                                <Label id="ValidFromLabelId" text="{i18n>validFrom}" design="Bold" />
                                <Text id="ValidFromTextId"
                                    text="{path:'UserDetailData>/ValidFrom', formatter:'.formatter.formatISODate'}" />

                                <Label id="ValidToLabelId" text="{i18n>validTo}" design="Bold"
                                    class="sapUiSmallMarginTop" />
                                <Text id="ValidToTextId"
                                    text="{path:'UserDetailData>/ValidTo', formatter:'.formatter.formatISODate'}" />
                            </VBox>

                            <VBox id="BoxCreationInfo">
                                <Label id="CreatedByLabelId" text="{i18n>createdBy}" design="Bold" />
                                <Text id="CreatedByTextId" text="{UserDetailData>/Creator}" />

                                <Label id="CreatedOnLabelId" text="{i18n>createdOn}" design="Bold"
                                    class="sapUiSmallMarginTop" />
                                <Text id="CreatedOnTextId"
                                    text="{path:'UserDetailData>/CreateOn', formatter:'.formatter.formatISODate'}" />
                            </VBox>
                        </layout:Grid>
                    </f:ObjectPageSubSection>
                </f:subSections>
            </f:ObjectPageSection>

            <!-- AUTHENTICATION -->
            <f:ObjectPageSection id="UserDetailSectionAuth" title="{i18n>auth}">
                <f:subSections>
                    <f:ObjectPageSubSection id="UserDetailSubSectionAuth">
                        <VBox id="AuthBoxId" class="sapUiMediumMargin sapUiContentPadding">
                            <!-- AUTH - DONUT CHART -->
                            <HBox id="hBoxChart" class="sapUiSmallMarginBottom"
                                justifyContent="SpaceAround">
                                <viz:VizFrame id="AuthVizFrameId" height="300px" width="500px"
                                    vizType="donut"
                                    vizProperties="{
                                    title: {
                                        text: 'User Authentication Result'
                                    },
                                    plotArea: {
                                        dataLabel: {
                                            visible: true
                                        },
                                        dataPointStyle: {
                                            rules: [
                                                {
                                                    dataContext: { 'Login Result': 'SUCCESS' },
                                                    properties: { color: '#2ecc71' },
                                                    displayName: 'Login Success'
                                                },
                                                {
                                                    dataContext: { 'Login Result': 'FAIL' },
                                                    properties: { color: '#e74c3c' },
                                                    displayName: 'Login Fail'
                                                }
                                            ]
                                        }
                                    },
                                    legend: {
                                        visible: true
                                    }
                                }">
                                    <!-- Define data of chart -->
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset id="AuthDatasetId"
                                            data="{AuthLogChartByUserData>/}">
                                            <!-- Category -->
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition
                                                    id="AuthDimLoginResultId" name="Login Result"
                                                    value="{AuthLogChartByUserData>LoginResult}" />
                                            </viz.data:dimensions>

                                            <!-- Value  -->
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition id="AuthMeasureCountId"
                                                    name="Count"
                                                    value="{AuthLogChartByUserData>CountLoginLog}" />
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>

                                    <!-- Mapping dimension/measure into chart -->
                                    <viz:feeds>
                                        <viz.feeds:FeedItem id="AuthFeedSizeId" uid="size"
                                            type="Measure" values="Count" />
                                        <viz.feeds:FeedItem id="AuthFeedColorId" uid="color"
                                            type="Dimension" values="Login Result" />
                                    </viz:feeds>
                                </viz:VizFrame>

                                <!-- AUTH PER DAY - COLUMN CHART -->
                                <viz:VizFrame id="AuthPerDayVizFrameId" height="300px" width="700px"
                                    vizType="column"
                                    vizProperties="{
                                    title: {
                                        text: 'User Log'
                                    },
                                    plotArea: {
                                        dataLabel: {
                                            visible: true,
                                            formatString: '0'
                                        }
                                    },
                                    valueAxis: {
                                        label: {
                                            formatString: '0'
                                        }
                                    },
                                    legend: {
                                        visible: true
                                    }
                                }">
                                    <!-- Define data of chart -->
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset id="AuthPerDayDatasetId"
                                            data="{UserAuthLogPerDayData>/}">
                                            <!-- DIMENSION -->
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition
                                                    id="AuthPerDayDimLoginResultId" name="Date"
                                                    value="{UserAuthLogPerDayData>LoginDate}" />
                                            </viz.data:dimensions>

                                            <!-- MEASURE -->
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition
                                                    id="AuthPerDayMeasureCountId" name="Login Count"
                                                    value="{UserAuthLogPerDayData>TotalLoginCount}" />
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>

                                    <!-- Mapping dimension/measure into chart -->
                                    <viz:feeds>
                                        <viz.feeds:FeedItem id="AuthPerDayFeedSizeId"
                                            uid="categoryAxis" type="Dimension" values="Date" />
                                        <viz.feeds:FeedItem id="AuthPerDayFeedColorId"
                                            uid="valueAxis" type="Measure" values="Login Count" />
                                    </viz:feeds>
                                </viz:VizFrame>
                            </HBox>
                            <!-- AUTHENTICATION -->
                            <Panel id="authFilterPanel" width="100%"
                                headerText="{i18n>filter}"
                                expandable="true" expanded="true"
                                class="customFilterPanel sapUiSmallMarginBottom">
                                <content>
                                    <Toolbar id="AuthToolbarId" class="sapUiSmallMarginBottom"
                                        design="Transparent">
                                        <!-- STATUS -->
                                        <Label id="AuthStatusLabelId" text="{i18n>status}"
                                            class="sapUiSmallMarginBegin sapUiSmallMarginEnd" />

                                        <Select id="AuthStatusSelectId" width="180px"
                                            change="onFilterAuth"
                                            class="sapUiSmallMarginEnd">
                                            <core:Item id="AuthStatusAllItemId" key=""
                                                text="{i18n>all}" />
                                            <core:Item id="AuthStatusSuccessItemId" key="SUCCESS"
                                                text="{i18n>success}" />
                                            <core:Item id="AuthStatusFailedItemId" key="FAIL"
                                                text="{i18n>failed}" />
                                        </Select>

                                        <!-- DATE -->
                                        <Label id="AuthDateLabelId" text="{i18n>filterDate}"
                                            class="sapUiSmallMarginBegin sapUiSmallMarginEnd" />
                                        <DatePicker id="AuthDatePickerId" width="180px"
                                            placeholder="{i18n>selectDate}"
                                            change="onFilterAuthLoginDate"
                                            class="sapUiSmallMarginEnd" />
                                    </Toolbar>
                                </content>
                            </Panel>
                            <!-- AUTH TABLE -->
                            <ui:Table id="AuthTableId"
                                rows="{
                                path: 'UserAuthLogData>/',
                                sorter: {
                                    path: 'LoginDate',
                                    descending: true
                                }
                            }"
                                visibleRowCount="8" selectionMode="Single" alternateRowColors="true"
                                class="sapUiLargeMarginBottom">

                                <!-- HEADER -->
                                <ui:extension>
                                    <OverflowToolbar id="AuthTableToolbarId">

                                        <Title id="AuthTableTitleId" text="{i18n>headerTitleTable}"
                                            level="H2" />

                                        <ToolbarSpacer id="ToolbarSpacer" />

                                        <!-- EXPORT -->
                                        <Button id="AuthExportButtonId"
                                            icon="sap-icon://excel-attachment"
                                            tooltip="{i18n>exportExcel}" press="onExportAuthExcel" />

                                        <!-- SETTINGS -->
                                        <Button id="AuthSettingsButtonId"
                                            icon="sap-icon://action-settings"
                                            tooltip="{i18n>viewSettings}" press="onOpenAuthSettings" />
                                    </OverflowToolbar>
                                </ui:extension>

                                <!-- COLUMNS -->
                                <ui:columns>
                                    <!-- SESSION ID -->
                                    <ui:Column id="AuthSessionIdColumnId" width="14rem"
                                        sortProperty="UserAuthLogData>SessionId"
                                        tooltip="{i18n>introSort}">
                                        <Label id="AuthSessionIdLabelId" text="{i18n>sessionId}" />
                                        <ui:template>
                                            <Text id="AuthSessionIdTextId"
                                                text="{UserAuthLogData>SessionId}" wrapping="false" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- LOGIN RESULT -->
                                    <ui:Column id="AuthLoginResultColumnId" width="9rem"
                                        sortProperty="UserAuthLogData>LoginResult"
                                        tooltip="{i18n>introSort}">
                                        <Label id="AuthLoginResultLabelId" text="{i18n>loginResult}" />
                                        <ui:template>
                                            <ObjectStatus id="AuthLoginResultStatusId"
                                                text="{UserAuthLogData>LoginResult}"
                                                icon="{path:'UserAuthLogData>LoginResult', formatter:'.formatter.formatLoginResultIcon'}"
                                                state="{path:'UserAuthLogData>LoginResult', formatter:'.formatter.formatLoginResultState'}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- LOGIN DATE -->
                                    <ui:Column id="AuthLoginDateColumnId" width="10rem"
                                        sortProperty="UserAuthLogData>LoginDate"
                                        tooltip="{i18n>introSort}">
                                        <Label id="AuthLoginDateLabelId" text="{i18n>loginDate}" />
                                        <ui:template>
                                            <Text id="AuthLoginDateTextId"
                                                text="{path:'UserAuthLogData>LoginDate', formatter:'.formatter.formatISODate'}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- LOGIN TIME -->
                                    <ui:Column id="AuthLoginTimeColumnId" width="8rem"
                                        sortProperty="UserAuthLogData>LoginTime"
                                        tooltip="{i18n>introSort}">
                                        <Label id="AuthLoginTimeLabelId" text="{i18n>loginTime}" />
                                        <ui:template>
                                            <Text id="AuthLoginTimeTextId"
                                                text="{UserAuthLogData>LoginTime}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- LOGIN MESSAGE -->
                                    <ui:Column id="AuthLoginMessageColumnId"
                                        sortProperty="UserAuthLogData>LoginMessage"
                                        tooltip="{i18n>introSort}">
                                        <Label id="AuthLoginMessageLabelId"
                                            text="{i18n>loginMessage}" />
                                        <ui:template>
                                            <ObjectStatus id="AuthLoginMessageStatusId"
                                                text="{UserAuthLogData>LoginMessage}"
                                                icon="{path:'UserAuthLogData>EventId', formatter:'.formatter.formatLoginMessageIcon'}"
                                                state="{path:'UserAuthLogData>EventId', formatter:'.formatter.formatLoginMessageState'}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- LOGOUT DATE -->
                                    <ui:Column id="AuthLogoutDateColumnId" width="10rem"
                                        sortProperty="UserAuthLogData>LogoutDate"
                                        tooltip="{i18n>introSort}">
                                        <Label id="AuthLogoutDateLabelId" text="{i18n>logoutDate}" />
                                        <ui:template>
                                            <Text id="AuthLogoutDateTextId"
                                                text="{path:'UserAuthLogData>LogoutDate', formatter:'.formatter.formatISODate'}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- LOGOUT TIME -->
                                    <ui:Column id="AuthLogoutTimeColumnId" width="8rem"
                                        sortProperty="UserAuthLogData>LogoutTime"
                                        tooltip="{i18n>introSort}">
                                        <Label id="AuthLogoutTimeLabelId" text="{i18n>logoutTime}" />
                                        <ui:template>
                                            <Text id="AuthLogoutTimeTextId"
                                                text="{path:'UserAuthLogData>LogoutTime', formatter:'.formatter.formatLogoutTime'}" />
                                        </ui:template>
                                    </ui:Column>

                                    <!-- NAVIGATE -->
                                    <ui:Column id="AuthNavigateColumnId" width="5rem"
                                        hAlign="Center">
                                        <ui:template>
                                            <Button id="AuthNavigateButtonId"
                                                icon="sap-icon://navigation-right-arrow"
                                                type="Transparent" press="onNavigationToAuthDetail" />
                                        </ui:template>
                                    </ui:Column>
                                </ui:columns>
                            </ui:Table>
                        </VBox>
                    </f:ObjectPageSubSection>
                </f:subSections>
            </f:ObjectPageSection>

            <!-- ACTIVITY -->
            <f:ObjectPageSection id="UserDetailSectionActivity" title="{i18n>activity}">
                <f:subSections>
                    <f:ObjectPageSubSection id="UserDetailSubSectionActivity">
                        <VBox id="ActivityVBoxId" class="sapUiMediumMargin sapUiContentPadding">
                            <HBox id="hBoxActChart" class="sapUiSmallMarginBottom"
                                justifyContent="SpaceAround">
                                <!-- TCODE USAGE - PIE CHART -->
                                <viz:VizFrame
                                    vizProperties="{
                                    title: { visible: true, text: 'Top 5 TCode Usage By User' },
                                    plotArea: {
                                        dataLabel: {
                                            visible: true,
                                            type: 'percentage'
                                        }
                                    }
                                }"
                                    id="tcodeChartByUser" vizType="pie" width="670px" height="300px">
                                    <!-- Define data of chart -->
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset id="TCodeByUserDatasetId"
                                            data="{TCodeByUserData>/}">
                                            <!-- DIMENSION -->
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition id="TCodeByUserDimId"
                                                    name="Label" value="{TCodeByUserData>Label}" />
                                            </viz.data:dimensions>

                                            <!-- MEASURE -->
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition
                                                    id="TCodeByUserMeasureCountId" name="Usage"
                                                    value="{TCodeByUserData>TCodeCount}" />
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>

                                    <!-- Mapping dimension/measure into chart -->
                                    <viz:feeds>
                                        <viz.feeds:FeedItem id="ActTcodeMeasure" uid="size"
                                            type="Measure" values="Usage" />
                                        <viz.feeds:FeedItem id="ActTcodeValue" uid="color"
                                            type="Dimension" values="Label" />
                                    </viz:feeds>
                                </viz:VizFrame>

                                <!-- ACTIVITY PERDAY - LINE CHART -->
                                <viz:VizFrame
                                    vizProperties="{
                                    title: { visible: true, text: 'Activity of User' }
                                }"
                                    id="idLineChart" width="600px" height="400px" vizType="line">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset id="ActDatasetId"
                                            data="{ActPerDateData>/}">
                                            <!-- DIMENSION -->
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition id="ActDimId"
                                                    name="Date"
                                                    value="{ActPerDateData>ActivityDate}" />
                                            </viz.data:dimensions>

                                            <!-- MEASURE -->
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition id="ActMeasureCountId"
                                                    name="Activity Count"
                                                    value="{ActPerDateData>ActivityCount}" />
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>

                                    <!-- Mapping dimension/measure into chart -->
                                    <viz:feeds>
                                        <viz.feeds:FeedItem id="ActMeasure" uid="valueAxis"
                                            type="Measure" values="Activity Count" />
                                        <viz.feeds:FeedItem id="ActValue" uid="categoryAxis"
                                            type="Dimension" values="Date" />
                                    </viz:feeds>
                                </viz:VizFrame>
                            </HBox>

                            <!-- ACTIVITY -->
                            <VBox id="ActivityVBoxContentId" class="sapUiMediumMarginTop">
                                <!-- FILTER BAR -->
                                <Panel id="activityUserFilterPanel"
                                    width="100%"
                                    headerText="{i18n>filter}"
                                    expandable="true"
                                    expanded="true"
                                    class="customFilterPanel sapUiSmallMarginBottom">
                                    <Toolbar id="ActivityUserToolbarId"
                                        class="sapUiSmallMarginBottom"
                                        design="Transparent">

                                        <!-- Activity Type -->
                                        <Label id="ActivityTypeLabelId" text="{i18n>activityType}"
                                            class="sapUiTinyMarginEnd" />

                                        <Select id="ActivityTypeSelectId" width="140px"
                                            change="onFilterActivity">
                                            <core:Item id="ActivityTypeAllItemId" key=""
                                                text="{i18n>all}" />
                                            <core:Item id="ActivityTypeTcodeItemId" key="TCODE"
                                                text="{i18n>itemTcode}" />
                                            <core:Item id="ActivityTypeDumpItemId" key="DUMP"
                                                text="{i18n>itemDump}" />
                                        </Select>
                                        <!-- Tcode -->
                                        <Label id="ActivityTCodeLabelId" text="{i18n>tCode}"
                                            class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />
                                        <Input id="ActivityTCodeInputId" width="200px"
                                            placeholder="{i18n>tCode}" showValueHelp="true"
                                            liveChange="onSearchTCode"
                                            valueHelpRequest="onUserSearchHelpTCode"
                                            showClearIcon="true" class="sapUiSmallMarginEnd" />

                                        <!-- Date -->
                                        <Label id="ActivityDateLabelId" text="{i18n>activityDate}"
                                            class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />
                                        <DatePicker id="ActivityDatePickerId" width="150px"
                                            placeholder="{i18n>selectDate}"
                                            change="onFilterActivity" />
                                    </Toolbar>
                                </Panel>

                                <!-- TABLE -->
                                <ui:Table id="ActivityTableId"
                                    rows="{
                                    path: 'UserActivityLogData>/',
                                    sorter: {
                                        path: 'ActivityDate',
                                        descending: true
                                    }
                                }"
                                    visibleRowCount="8" selectionMode="None"
                                    alternateRowColors="true" class="sapUiLargeMarginBottom">
                                    <!-- HEADER TOOLBAR -->
                                    <ui:extension>
                                        <OverflowToolbar id="ActivityTableToolbarId">
                                            <Title id="ActivityTableTitleId"
                                                text="{i18n>activityTable}"
                                                level="H2" />
                                            <ToolbarSpacer id="ActivityTableSpacerId" />

                                            <!-- EXPORT -->
                                            <Button id="ActivityExportButtonId"
                                                icon="sap-icon://excel-attachment"
                                                tooltip="{i18n>exportExcel}"
                                                press="onExportActivityExcel" />

                                            <!-- SETTINGS -->
                                            <Button id="ActivitySettingsButtonId"
                                                icon="sap-icon://action-settings"
                                                tooltip="{i18n>viewSettings}"
                                                press="onOpenActivitySettings" />
                                        </OverflowToolbar>
                                    </ui:extension>

                                    <!-- COLUMNS -->
                                    <ui:columns>
                                        <!-- LOG ID -->
                                        <ui:Column id="ActivityLogIdColumnId" width="14rem"
                                            sortProperty="UserActivityLogData>LogId"
                                            tooltip="{i18n>introSort}">
                                            <Label id="ActivityLogIdLabelId" text="{i18n>logId}" />
                                            <ui:template>
                                                <Text id="ActivityLogIdTextId"
                                                    text="{UserActivityLogData>LogId}"
                                                    wrapping="false" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- ACTIVITY TYPE -->
                                        <ui:Column id="ActivityTypeColumnId" width="10rem"
                                            hAlign="Center"
                                            sortProperty="UserActivityLogData>ActivityType"
                                            tooltip="{i18n>introSort}">
                                            <Label id="ActivityTypeColumnLabelId"
                                                text="{i18n>activityType}" />
                                            <ui:template>
                                                <ObjectStatus id="ActivityTypeStatusId"
                                                    text="{UserActivityLogData>ActivityType}"
                                                    icon="{path:'UserActivityLogData>ActivityType', formatter:'.formatter.formatActivityType'}"
                                                    state="{path:'UserActivityLogData>ActivityType', formatter:'.formatter.formatActivityState'}" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- TCODE -->
                                        <ui:Column id="ActivityTCodeColumnId" width="8rem"
                                            sortProperty="UserActivityLogData>TCode"
                                            tooltip="{i18n>introSort}">
                                            <Label id="ActivityTCodeColumnLabelId"
                                                text="{i18n>tCode}" />
                                            <ui:template>
                                                <ObjectStatus id="ActivityTCodeStatusId"
                                                    text="{UserActivityLogData>TCode}"
                                                    icon="{path:'UserActivityLogData>TCode', formatter:'.formatter.formatTCodeIcon'}" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- TCODE NAME -->
                                        <ui:Column id="ActivityTCodeNameColumnId" width="12rem"
                                            sortProperty="UserActivityLogData>TCodeName"
                                            tooltip="{i18n>introSort}">
                                            <Label id="ActivityTCodeNameLabelId"
                                                text="{i18n>tCodeName}" />
                                            <ui:template>
                                                <Text id="ActivityTCodeNameTextId"
                                                    text="{UserActivityLogData>TCodeName}"
                                                    wrapping="false" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- MESSAGE -->
                                        <ui:Column id="ActivityMessageColumnId"
                                            sortProperty="UserActivityLogData>ActivityMessage"
                                            tooltip="{i18n>introSort}">
                                            <Label id="ActivityMessageLabelId"
                                                text="{i18n>activityMessage}" />
                                            <ui:template>
                                                <ObjectStatus id="ActivityMessageStatusId"
                                                    text="{UserActivityLogData>ActivityMessage}"
                                                    state="Information" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- DATE -->
                                        <ui:Column id="ActivityDateColumnId" width="10rem"
                                            sortProperty="UserActivityLogData>ActivityDate"
                                            tooltip="{i18n>introSort}">
                                            <Label id="ActivityDateColumnLabelId"
                                                text="{i18n>activityDate}" />
                                            <ui:template>
                                                <Text id="ActivityDateTextId"
                                                    text="{path:'UserActivityLogData>ActivityDate', formatter: '.formatter.formatISODate'}" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- TIME -->
                                        <ui:Column id="ActivityTimeColumnId" width="8rem"
                                            sortProperty="UserActivityLogData>ActivityTime"
                                            tooltip="{i18n>introSort}">
                                            <Label id="ActivityTimeColumnLabelId"
                                                text="{i18n>activityTime}" />
                                            <ui:template>
                                                <Text id="ActivityTimeTextId"
                                                    text="{UserActivityLogData>ActivityTime}" />
                                            </ui:template>
                                        </ui:Column>

                                        <!-- SENT MAIL -->
                                        <ui:Column id="ActivityNavigateColumnId" width="4rem"
                                            hAlign="Center">
                                            <Label id="ActivitySentMaileColumnLabelId"
                                                text="{i18n>sentMailAlert}" />
                                            <ui:template>
                                                <core:Icon id="ActivitySentMail"
                                                    src="{= ${detailData>mail_sent} ? 'sap-icon://email' : 'sap-icon://less'}"
                                                    color="{= ${detailData>mail_sent} ? 'Positive' : 'Neutral'}"
                                                    size="1.5rem" />
                                            </ui:template>
                                        </ui:Column>
                                    </ui:columns>
                                </ui:Table>
                            </VBox>
                        </VBox>
                    </f:ObjectPageSubSection>
                </f:subSections>
            </f:ObjectPageSection>
        </f:sections>
    </f:ObjectPageLayout>
</mvc:View>