<mvc:View xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m" controllerName="useraudit.controller.AuthDetail"
    xmlns:f="sap.uxap"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:ui="sap.ui.table"
    height="100%">
    <f:ObjectPageLayout id="AuthDetailObjectPageLayoutId">
        <!-- HEADER -->
        <f:headerTitle>
            <!-- TITLE | SUBTITLE -->
            <f:ObjectPageDynamicHeaderTitle id="HeaderTitleId">
                <f:heading>
                    <Title id="TitleSession" text="{detailData>/SessionId}" level="H2" />
                </f:heading>
                <f:expandedContent>
                    <Text id="SubTitle" text="{i18n>subTitle}" />
                </f:expandedContent>
            </f:ObjectPageDynamicHeaderTitle>
        </f:headerTitle>

        <f:headerContent>
            <!-- USER CARD -->
            <HBox id="HeaderUserHBox" class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">
                <!-- AVATAR -->
                <Avatar id="AvatarUser" displaySize="L" class="sapUiSmallMarginEnd" />

                <VBox id="UserInfoBox">
                    <!-- TITLE -->
                    <Title id="TitleUsername" text="{detailData>/Username}" level="H5" />

                    <!-- LOGIN RESULT -->
                    <ObjectStatus id="StatusLoginResultHeader" text="{detailData>/LoginResult}"
                        state="{
                        path: 'detailData>/LoginResult',
                        formatter: '.formatter.formatLoginResultState'
                    }"
                        icon="{
                        path: 'detailData>/LoginResult',
                        formatter: '.formatter.formatLoginResultIcon'
                    }"
                        class="sapUiSmallMarginBottom" />

                    <Label id="LabelClient" text="{i18n>client}" design="Bold" />
                    <Text id="TextClient" text="{i18n>clientNum}" />
                </VBox>
            </HBox>
        </f:headerContent>

        <!-- SECTIONS -->
        <f:sections>
            <!-- DETAIL SECTIONS -->
            <f:ObjectPageSection id="SectionDetail" title="{i18n>detailSectionTitle}">
                <f:subSections>
                    <f:ObjectPageSubSection id="SubSectionDetail">
                        <layout:Grid id="GridDetail" defaultSpan="L2 M4 S12">
                            <!-- COLUMN 1 -->
                            <VBox id="BoxUserInfo">
                                <!-- USER SESSION -->
                                <Label id="LabelSessionId" text="{i18n>sessionId}" design="Bold" />
                                <Text id="TextSessionId" text="{detailData>/SessionId}" />

                                <!-- USERNAME -->
                                <Label id="LabelUsername" text="{i18n>username}" design="Bold"
                                    class="sapUiSmallMarginTop" />
                                <Text id="TextUsername" text="{detailData>/Username}" />
                            </VBox>

                            <!-- COLUMN 2 -->
                            <VBox id="BoxLoginResult">
                                <!-- LOGIN RESULT -->
                                <Label id="LabelLoginResultId" text="{i18n>loginResult}"
                                    design="Bold" />
                                <ObjectStatus id="StatusLoginResultId"
                                    text="{detailData>/LoginResult}"
                                    state="{path: 'detailData>/LoginResult', formatter: '.formatter.formatLoginResultState'}"
                                    icon="{path: 'detailData>/LoginResult', formatter: '.formatter.formatLoginResultIcon'}" />

                                <!-- LOGIN MESSAGE -->
                                <Label id="LabelLoginMessageId" text="{i18n>loginMessage}"
                                    design="Bold" class="sapUiSmallMarginTop" />
                                <ObjectStatus id="StatusLoginMessageId"
                                    text="{detailData>/LoginMessage}"
                                    state="{path: 'detailData>/EventId', formatter: '.formatter.formatLoginMessageState'}"
                                    icon="{path: 'detailData>/EventId', formatter: '.formatter.formatLoginMessageIcon'}" />
                            </VBox>

                            <!-- COLUMN 3 -->
                            <VBox id="BoxEventInfo">
                                <!-- TERMINAL ID -->
                                <Label id="LabelTerminal" text="{i18n>terminalId}" design="Bold" />
                                <Text id="TextTerminal" text="{detailData>/TerminalId}" />
                                <!-- EVENT ID -->
                                <Label id="LabelEvent" text="{i18n>eventId}" design="Bold"
                                    class="sapUiSmallMarginTop" />
                                <ObjectStatus id="StatusEvent" text="{detailData>/EventId}"
                                    state="{path: 'detailData>/EventId', formatter: '.formatter.formatLoginMessageState'}" />
                            </VBox>

                            <!-- COLUMN 4 -->
                            <VBox id="BoxLoginTimeInfo">
                                <!-- LOGIN DATE -->
                                <Label id="LabelLoginDateId" text="{i18n>loginDate}" design="Bold" />
                                <Text id="TextLoginDateId"
                                    text="{path:'detailData>/LoginDate', formatter: '.formatter.formatISODate'}" />
                                <!-- LOGIN TIME -->
                                <Label id="LabelLoginTimeId" text="{i18n>loginTime}" design="Bold"
                                    class="sapUiSmallMarginTop" />
                                <Text id="TextLoginTimeId" text="{detailData>/LoginTime}" />
                            </VBox>

                            <!-- COLUMN 5 -->
                            <VBox id="BoxLogoutTimeInfo">
                                <!-- LOGOUT DATE -->
                                <Label id="LabelLogoutDateId" text="{i18n>logoutDate}" design="Bold" />
                                <Text id="TextLogoutDateId"
                                    text="{path:'detailData>/LogoutDate', formatter: '.formatter.formatISODate'}" />
                                <!-- LOGOUT TIME -->
                                <Label id="LabelLogoutTimeId" text="{i18n>logoutTime}" design="Bold"
                                    class="sapUiSmallMarginTop" />
                                <Text id="TextLogoutTimeId"
                                    text="{path:'detailData>/LogoutTime', formatter: '.formatter.formatLogoutTime'}" />
                            </VBox>

                            <!-- COLUMN 6 -->
                            <VBox id="BoxEmail">
                                <!-- SEND EMAIL -->
                                <Label id="LabelSendEmailId" text="{i18n>sendEmail}" design="Bold" />
                                <core:Icon id="icon"
                                    src="{= ${detailData>/SendMailFlag} ? 'sap-icon://accept' : 'sap-icon://decline'}"
                                    color="{= ${detailData>/SendMailFlag} ? 'green' : 'red'}"
                                    size="1.5rem" />
                            </VBox>
                        </layout:Grid>
                    </f:ObjectPageSubSection>
                </f:subSections>
            </f:ObjectPageSection>

            <!-- ACTIVITY SECTIONS -->
            <f:ObjectPageSection id="SectionActivity" title="{i18n>activityLog}">
                <f:subSections>
                    <f:ObjectPageSubSection id="SubSectionActivity">
                        <VBox>

                            <!-- FILTER TOOLBAR -->
                            <Toolbar class="sapUiSmallMarginBottom" design="Transparent">
                                <ToolbarSpacer />

                                <Label text="{i18n>activityType}" class="sapUiTinyMarginEnd" />

                                <Select id="activityTypeFilter"
                                    width="180px"
                                    change="onFilterActivityType">
                                    <core:Item key="" text="{i18n>itemAll}" />
                                    <core:Item key="TCODE" text="{i18n>itemTcode}" />
                                    <core:Item key="DUMP" text="{i18n>itemDump}" />
                                </Select>
                            </Toolbar>
                            <!-- TABLE -->
                            <ui:Table
                                id="ActivityTable"
                                rows="{detailData>/_Activity}"
                                visibleRowCount="12"
                                selectionMode="None"
                                alternateRowColors="true">
                                <ui:extension>
                                    <OverflowToolbar>

                                        <!-- TITLE
                                        <Title text="{i18n>activityLog}" level="H6" /> -->

                                        <ToolbarSpacer />

                                        <!-- EXPORT -->
                                        <Button
                                            icon="sap-icon://excel-attachment"
                                            tooltip="Export Excel"
                                            press="onExportActivityExcel" />

                                        <!-- SETTINGS -->
                                        <Button
                                            icon="sap-icon://action-settings"
                                            tooltip="Settings"
                                            press="onOpenActivitySettings" />

                                    </OverflowToolbar>
                                </ui:extension>
                                <ui:columns>
                                    <!-- LOGID COLUMN -->
                                    <ui:Column id="ColumnLogId" width="18rem">
                                        <Label text="{i18n>logId}" />
                                        <ui:template>
                                            <Text text="{detailData>LogId}" wrapping="false" />
                                        </ui:template>
                                    </ui:Column>
                                    <!-- ACTIVITY TYPE COLUMN -->
                                    <ui:Column id="ColumnActivityTypeId" width="8rem">
                                        <Label text="{i18n>activityType}" />
                                        <ui:template>
                                            <Text text="{detailData>ActivityType}" wrapping="false" />
                                        </ui:template>
                                    </ui:Column>
                                    <!-- TCODE COLUMN -->
                                    <ui:Column id="ColumnTCodeId" width="6rem">
                                        <Label text="{i18n>tCode}" />
                                        <ui:template>
                                            <HBox alignItems="Center" renderType="Bare">
                                                <core:Icon src="sap-icon://customer-and-contacts"
                                                    size="0.9rem" class="sapUiTinyMarginEnd" />
                                                <Text text="{detailData>TCode}" wrapping="false" />
                                            </HBox>
                                        </ui:template>
                                    </ui:Column>
                                    <!-- TCODE NAME COLUMN -->
                                    <ui:Column id="ColumnTCodeNameId" width="8rem">
                                        <Label text="{i18n>tCodeName}" />
                                        <ui:template>
                                            <Text text="{detailData>TCodeName}" wrapping="false" />
                                        </ui:template>
                                    </ui:Column>
                                    <!-- ACTIVITY MESSAGE COLUMN -->
                                    <ui:Column id="ColumnMsgId">
                                        <Label text="{i18n>activityMessage}" />
                                        <ui:template>
                                            <ObjectStatus
                                                text="{detailData>ActivityMessage}"
                                                state="Information" />
                                        </ui:template>
                                    </ui:Column>
                                    <!-- TIME COLUMN -->
                                    <ui:Column id="ColumnTieId" width="8rem">
                                        <Label text="{i18n>activityTime}" />
                                        <ui:template>
                                            <Text text="{detailData>ActivityTime}" wrapping="false" />
                                        </ui:template>
                                    </ui:Column>

                                    <ui:Column width="4rem" hAlign="Center">
                                        <ui:template>
                                            <Button
                                                id="btnActivityNavigator"
                                                icon="sap-icon://navigation-right-arrow"
                                                type="Transparent"
                                                press="onPressActivityDetail" />
                                        </ui:template>
                                    </ui:Column>
                                </ui:columns>
                            </ui:Table>
                        </VBox>
                    </f:ObjectPageSubSection>
                </f:subSections>
            </f:ObjectPageSection>
        </f:sections>
    </f:ObjectPageLayout>
</mvc:View>